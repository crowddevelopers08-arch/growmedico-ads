# ============================================
# AdPulse - Environment Variables
# ============================================
# Copy this file to .env.local and fill in values

# --------------------------
# Database (PostgreSQL)
# --------------------------
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/adpulse"

# --------------------------
# NextAuth
# --------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars-change-in-production"

# --------------------------
# Admin Credentials (used in seed)
# --------------------------
ADMIN_EMAIL="admin@adpulse.com"
ADMIN_PASSWORD="ChangeMe123!"

# --------------------------
# Google Ads API (MCC / Manager Account)
# --------------------------
GOOGLE_ADS_DEVELOPER_TOKEN="your-developer-token"
GOOGLE_ADS_CLIENT_ID="your-oauth-client-id"
GOOGLE_ADS_CLIENT_SECRET="your-oauth-client-secret"
# MCC Manager Account ID — no dashes (e.g. 1234567890)
GOOGLE_ADS_LOGIN_CUSTOMER_ID="your-manager-account-id"
# Refresh token for the MCC account owner — used for ALL client syncs
GOOGLE_ADS_REFRESH_TOKEN="your-mcc-refresh-token"

# --------------------------
# Meta (Facebook) Marketing API
# --------------------------
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
META_API_VERSION="v21.0"

# --------------------------
# App Config
# --------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AdPulse"

# --------------------------
# Sync Configuration
# --------------------------
# Cron secret for automated sync (set in your cron job or scheduler)
CRON_SECRET="your-cron-secret-key"

# Alert threshold (default 80%)
BUDGET_ALERT_THRESHOLD="80"

# --------------------------
# WhatsApp Notifications (Twilio)
# --------------------------
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
# Sandbox: whatsapp:+14155238886  |  Production: whatsapp:+YOUR_VERIFIED_NUMBER
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# Admin phone that receives ALL budget alerts (E.164 format: +countrycode number)
WHATSAPP_ADMIN_PHONE="+1234567890"
